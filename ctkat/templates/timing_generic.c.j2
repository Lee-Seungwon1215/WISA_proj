#include <stdio.h>
#include <stdlib.h>
#include <string.h>

{% if clock == "rdtsc" -%}
#include <x86intrin.h>
{% else -%}
#include <time.h>
{% endif %}

{% for h in extra_headers -%}
#include "{{ h }}"
{% endfor %}

/* CTKAT_USE: force `x` to be materialized (treated as observed) before the
 * next instruction, and act as a compiler memory barrier. Defends against
 * the compiler eliding an unused return value or hoisting loads/stores
 * across the timed region. Pair with `-fno-lto` so the function body
 * itself can't be inlined and analyzed for purity. */
#define CTKAT_USE(x) __asm__ __volatile__("" : : "g"(x) : "memory")

#define CTKAT_MEASUREMENTS {{ measurements }}
#define CTKAT_WARMUP       {{ warmup }}
#define CTKAT_SEED         {{ seed }}ULL

/* xorshift64 — fast, deterministic, seedable. We avoid libc rand() because
 * it isn't reproducible across implementations and isn't thread-safe. */
static uint64_t prng_state;

static uint64_t prng_next(void) {
    uint64_t x = prng_state;
    x ^= x << 13;
    x ^= x >> 7;
    x ^= x << 17;
    /* xorshift's only forbidden state is 0; fall back if we ever hit it. */
    prng_state = x ? x : 0xC0FFEEULL;
    return prng_state;
}

static void prng_init(uint64_t seed) {
    prng_state = seed ? seed : 0xC0FFEEULL;
    for (int i = 0; i < 8; i++) (void)prng_next();
}

static void rand_bytes(uint8_t *buf, size_t len) {
    for (size_t i = 0; i < len; i++) {
        buf[i] = (uint8_t)(prng_next() & 0xff);
    }
}

{% if clock == "rdtsc" -%}
/* lfence on both sides of rdtscp gives a full serialization fence:
 *   - the leading lfence drains any in-flight insns before rdtscp samples,
 *   - rdtscp itself waits for prior insns to retire,
 *   - the trailing lfence prevents subsequent insns from speculating past
 *     rdtscp, which would otherwise let post-measurement work creep into
 *     the timed window on the next ctkat_now() call.
 * (On pre-Spectre AMD microcode lfence was advisory; modern microcode
 * makes it dispatch-serializing. Assumes a recent CPU.) */
static inline uint64_t ctkat_now(void) {
    unsigned int aux;
    _mm_lfence();
    uint64_t t = __rdtscp(&aux);
    _mm_lfence();
    return t;
}
{% else -%}
static inline uint64_t ctkat_now(void) {
    struct timespec ts;
    /* clock_gettime is a vDSO/syscall — already a compiler memory barrier
     * and a CPU sync point, so no extra fence is needed here. */
    clock_gettime(CLOCK_MONOTONIC_RAW, &ts);
    return (uint64_t)ts.tv_sec * 1000000000ULL + (uint64_t)ts.tv_nsec;
}
{% endif %}

/* Keep results in arrays and flush after the timed loop (doc §17.16 #9). */
static uint64_t cycles_buf[CTKAT_MEASUREMENTS];
static uint8_t  classes_buf[CTKAT_MEASUREMENTS];

int main(void) {
    prng_init(CTKAT_SEED);

    /* class-0 fixed secret buffers (filled once, reused every iteration) */
    {% for b in buffers if b.role == "secret" -%}
    uint8_t {{ b.name }}_fixed[{{ b.size }}];
    rand_bytes({{ b.name }}_fixed, sizeof({{ b.name }}_fixed));
    {% endfor %}

    /* working buffers (re-filled every iteration) */
    {% for b in buffers -%}
    uint8_t {{ b.name }}[{{ b.size }}];
    {% endfor %}

    /* warmup — discard timings */
    for (size_t i = 0; i < CTKAT_WARMUP; i++) {
        {% for b in buffers -%}
        rand_bytes({{ b.name }}, sizeof({{ b.name }}));
        {% endfor %}
        {{ function }}({{ args | join(", ") }});
    }

    for (size_t i = 0; i < CTKAT_MEASUREMENTS; i++) {
        /* Use a high bit (shifted right 32) instead of the LSB. xorshift64's
         * low bit has known weak diffusion — over short windows the 0/1
         * balance drifts noticeably. The upper word is much closer to
         * uniform, which matters because dudect's t-test needs the class
         * assignment to be unbiased. */
        int cls = (int)((prng_next() >> 32) & 1ULL);

        /* public + output buffers: always re-randomized */
        {% for b in buffers if b.role != "secret" -%}
        rand_bytes({{ b.name }}, sizeof({{ b.name }}));
        {% endfor %}

        /* secret buffers: fixed for class 0, fresh-random for class 1 */
        {% for b in buffers if b.role == "secret" -%}
        if (cls == 0) {
            memcpy({{ b.name }}, {{ b.name }}_fixed, sizeof({{ b.name }}));
        } else {
            rand_bytes({{ b.name }}, sizeof({{ b.name }}));
        }
        {% endfor %}

        uint64_t t0 = ctkat_now();
        {% if return_type and return_type != "void" -%}
        {{ return_type }} __ctkat_ret = {{ function }}({{ args | join(", ") }});
        CTKAT_USE(__ctkat_ret);
        {% else -%}
        {{ function }}({{ args | join(", ") }});
        {% endif %}
        uint64_t t1 = ctkat_now();

        /* Clamp underflow: t1 < t0 should be impossible on a single core
         * with serialized rdtsc, but TSC skew across cores (no affinity) or
         * a clock-anomaly can flip the order. uint64 underflow would yield
         * a ~1e19 spike that swamps t-score variance. Store 0 instead;
         * downstream cropping will discard it as an outlier. */
        cycles_buf[i]  = (t1 >= t0) ? (t1 - t0) : 0;
        classes_buf[i] = (uint8_t)cls;
    }

    printf("sample_id,class,cycles\n");
    for (size_t i = 0; i < CTKAT_MEASUREMENTS; i++) {
        printf("%zu,%u,%llu\n",
               i,
               (unsigned)classes_buf[i],
               (unsigned long long)cycles_buf[i]);
    }
    return 0;
}
