/* AUTO-GENERATED by CT-KAT (dudect timing harness, signature). DO NOT EDIT.
 *
 * Why a dedicated signature template (separate from timing_kem / generic):
 *   - The axis is fixed-sk vs fresh-sk with a FIXED message, analogous to the
 *     kem sk-leak mode. Both classes call crypto_sign_signature on a valid sk
 *     produced by crypto_sign_keypair; the keypair call lives OUTSIDE the
 *     timed region so only the signing path is measured.
 *   - Signing/keygen randomness is drawn from the weak `randombytes` override
 *     below (seeded by CTKAT_SEED), so runs are reproducible and the only
 *     thing differing between the two classes is the secret key.
 *
 * Note on variable-time signers (ML-DSA rejection sampling, Falcon Gaussian
 * sampling, SPHINCS+ hash trees): these have large *within-class* timing
 * variance by construction. That is the accepted variable-time behavior the
 * structural+triage layers already reason about; dudect's Welch test absorbs
 * it through the per-class variance term. A WARNING/FAIL here is therefore
 * expected for those targets and must not be read as a constant-time PASS.
 */

#include <stddef.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

{% if clock == "rdtsc" -%}
#include <x86intrin.h>
{% else -%}
#include <time.h>
{% endif %}

#include "{{ header }}"
{% for h in extra_headers -%}
#include "{{ h }}"
{% endfor %}

/* PQClean's randombytes.h does `#define randombytes PQCLEAN_randombytes`, so
 * the signer actually calls the namespaced symbol. Include it BEFORE the weak
 * override below so the macro rewrites our definition to PQCLEAN_randombytes
 * too — otherwise we'd define an unused literal `randombytes` and the link
 * fails on an undefined PQCLEAN_randombytes. (The kem template happens to get
 * this macro transitively through its headers; ML-DSA's api.h does not pull
 * randombytes.h, so we include it explicitly and portably here.) */
#include "randombytes.h"

#ifndef CTKAT_SIGN_MSG_LEN
#define CTKAT_SIGN_MSG_LEN 64
#endif

/* CTKAT_USE: force `x` to be materialized (treated as observed) before the
 * next instruction, and act as a compiler memory barrier. Defends against the
 * compiler eliding an unused return value or hoisting loads/stores across the
 * timed region. Pair with `-fno-lto` so the signer body itself can't be
 * inlined and analyzed for purity. Same pattern as timing_kem.c.j2. */
#define CTKAT_USE(x) __asm__ __volatile__("" : : "g"(x) : "memory")

#define CTKAT_MEASUREMENTS {{ measurements }}
#define CTKAT_WARMUP       {{ warmup }}
#define CTKAT_SEED         {{ seed }}ULL

static uint64_t prng_state;

static uint64_t prng_next(void) {
    uint64_t x = prng_state;
    x ^= x << 13;
    x ^= x >> 7;
    x ^= x << 17;
    prng_state = x ? x : 0xC0FFEEULL;
    return prng_state;
}

static void prng_init(uint64_t seed) {
    prng_state = seed ? seed : 0xC0FFEEULL;
    for (int i = 0; i < 8; i++) (void)prng_next();
}

static void rand_bytes(uint8_t *buf, size_t len) {
    for (size_t i = 0; i < len; i++) {
        buf[i] = (uint8_t)(prng_next() & 0xff);
    }
}

/* Override PQClean's `randombytes` so keypair/sign draw from our xorshift
 * PRNG (seeded by CTKAT_SEED) rather than OS entropy. Exclude PQClean's
 * `common/randombytes.c` from the dudect harness `sources:` so this becomes
 * the only definition → keygen/signing deterministic across runs. The `weak`
 * attribute keeps legacy setups that still link randombytes.c working (the
 * strong symbol wins there). GCC/Clang only. See timing_kem.c.j2. */
__attribute__((weak)) int randombytes(uint8_t *buf, size_t len) {
    rand_bytes(buf, len);
    return 0;
}

{% if clock == "rdtsc" -%}
/* See timing_generic.c.j2 for the lfence-rdtscp-lfence rationale. Same fence
 * on both ends so inflight insns drain before, and subsequent insns cannot
 * speculate past, the cycle sample. */
static inline uint64_t ctkat_now(void) {
    unsigned int aux;
    _mm_lfence();
    uint64_t t = __rdtscp(&aux);
    _mm_lfence();
    return t;
}
{% else -%}
static inline uint64_t ctkat_now(void) {
    struct timespec ts;
    /* clock_gettime is a vDSO/syscall — already a compiler memory barrier and
     * a CPU sync point, so no extra fence is needed here. */
    clock_gettime(CLOCK_MONOTONIC_RAW, &ts);
    return (uint64_t)ts.tv_sec * 1000000000ULL + (uint64_t)ts.tv_nsec;
}
{% endif %}

static uint64_t cycles_buf[CTKAT_MEASUREMENTS];
static uint8_t  classes_buf[CTKAT_MEASUREMENTS];

int main(void) {
    prng_init(CTKAT_SEED);

    /* sk is the fixed-vs-fresh axis; msg is held constant. class 0 always
     * signs under sk_fixed; class 1 signs under a fresh keypair generated
     * OUTSIDE the timed region. Detects sk-dependent timing in the signer. */
    uint8_t pk_fixed [{{ prefix }}CRYPTO_PUBLICKEYBYTES];
    uint8_t sk_fixed [{{ prefix }}CRYPTO_SECRETKEYBYTES];
    uint8_t pk_random[{{ prefix }}CRYPTO_PUBLICKEYBYTES];
    uint8_t sk_random[{{ prefix }}CRYPTO_SECRETKEYBYTES];
    uint8_t msg[CTKAT_SIGN_MSG_LEN] = {0};
    /* CRYPTO_BYTES is the upper bound on signature length; siglen is set by
     * the implementation (fixed for ML-DSA, variable for Falcon/SPHINCS+). */
    uint8_t sig[{{ prefix }}CRYPTO_BYTES];
    size_t siglen = 0;

    /* class-0 fixed keypair — held constant for the whole run. */
    {{ prefix }}crypto_sign_keypair(pk_fixed, sk_fixed);

    /* warmup — burn-in microarch state by signing under sk_fixed (the same
     * normal path the measured loop exercises). */
    for (size_t i = 0; i < CTKAT_WARMUP; i++) {
        {{ prefix }}crypto_sign_signature(sig, &siglen, msg, sizeof(msg), sk_fixed);
    }

    for (size_t i = 0; i < CTKAT_MEASUREMENTS; i++) {
        /* High bit (>>32), not the LSB: xorshift64's LSB has weak diffusion
         * and would bias the 0/1 class split that the t-test relies on. */
        int cls = (int)((prng_next() >> 32) & 1ULL);

        uint8_t *sk;
        if (cls == 0) {
            sk = sk_fixed;
        } else {
            /* Fresh keypair — call is OUTSIDE the timed region. */
            {{ prefix }}crypto_sign_keypair(pk_random, sk_random);
            sk = sk_random;
        }

        /* Cache-balance step: warm-sign the SAME sk so both classes enter the
         * timed region with cache state normalized to "just-signed-this-sk".
         * Without it the class-1 fresh keypair() above churns the cache/branch
         * predictor asymmetrically vs class-0, biasing the measurement. Mirror
         * of the kem template's warm-dec step (F14). */
        {{ prefix }}crypto_sign_signature(sig, &siglen, msg, sizeof(msg), sk);

        uint64_t t0 = ctkat_now();
        /* Capture + CTKAT_USE the return so the optimizer can't decide the
         * call is unobserved and elide it. PQClean signer returns int. */
        int __ctkat_sig_rc =
            {{ prefix }}crypto_sign_signature(sig, &siglen, msg, sizeof(msg), sk);
        CTKAT_USE(__ctkat_sig_rc);
        uint64_t t1 = ctkat_now();

        /* Sink siglen + the signature bytes AFTER t1 (so the consume cost
         * isn't charged to the measurement) — a header/inline signer could
         * otherwise elide the work that fills `sig` while keeping `rc`, giving
         * a false PASS. Real PQClean signers are external under -fno-lto so
         * this is belt-and-suspenders, matching timing_kem.c.j2. */
        {
            volatile uint64_t __ctkat_sink = 0;
            __ctkat_sink ^= (uint64_t)siglen;
            for (size_t __ctkat_si = 0;
                 __ctkat_si < siglen && __ctkat_si < sizeof(sig);
                 __ctkat_si++) {
                __ctkat_sink ^= (uint64_t)sig[__ctkat_si];
            }
            CTKAT_USE(__ctkat_sink);
        }

        /* Clamp underflow — see timing_generic.c.j2 for rationale. */
        cycles_buf[i]  = (t1 >= t0) ? (t1 - t0) : 0;
        classes_buf[i] = (uint8_t)cls;
    }

    printf("sample_id,class,cycles\n");
    for (size_t i = 0; i < CTKAT_MEASUREMENTS; i++) {
        printf("%zu,%u,%llu\n",
               i,
               (unsigned)classes_buf[i],
               (unsigned long long)cycles_buf[i]);
    }
    return 0;
}
