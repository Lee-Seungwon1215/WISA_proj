{# Bundle H2 (T1): pull the shared "warm dec + measured dec + buffer write"
   block out of both leak_target branches so future changes (e.g. R1 Option
   B randombytes override, additional measurement gates) only need to touch
   one site. The macro takes `sk_expr` / `ct_expr` so each branch can plug
   in its own variable choice. -#}
{% macro emit_kem_measurement(sk_expr, ct_expr) -%}
        /* Cache-balance step (T1: shared by sk/ct/fo leak modes). The warm
         * dec runs the SAME (ct, sk) pair as the measured one so both
         * classes start the timed region with cache state actually
         * normalized to "just-ran-this-exact-path".
         *
         * F14: prior versions ran the warm dec with `rand_bytes(ct_warm)`,
         * i.e. always invalid ct → always the FO fallback path. That
         * defeated the cache-balance purpose for ct-leak / fo-leak (where
         * the measured dec is on the *normal* path for at least one
         * class) — the timed region would start cold relative to the
         * normal-path microarchitectural state. */
        {{ prefix }}crypto_kem_dec(ss, {{ ct_expr }}, {{ sk_expr }});

        uint64_t t0 = ctkat_now();
        /* Capture + CTKAT_USE the return so the optimizer can't decide the
         * call is unobserved and elide it. Assumes the PQClean `int` ABI. */
        int __ctkat_dec_rc = {{ prefix }}crypto_kem_dec(ss, {{ ct_expr }}, {{ sk_expr }});
        CTKAT_USE(__ctkat_dec_rc);
        uint64_t t1 = ctkat_now();

        /* Clamp underflow — see timing_generic.c.j2 for rationale. */
        cycles_buf[i]  = (t1 >= t0) ? (t1 - t0) : 0;
        classes_buf[i] = (uint8_t)cls;
{%- endmacro %}
/* AUTO-GENERATED by CT-KAT (dudect timing harness, KEM). DO NOT EDIT.
 *
 * Why a dedicated KEM template (separate from `timing_generic.c.j2`):
 *   - The generic template fills the secret buffer with random bytes, which
 *     for ML-KEM yields an *invalid* sk and forces the dec into its
 *     Fujisaki-Okamoto fallback path on every call. That defeats the point
 *     of fixed-vs-random timing — both classes would exercise the same path.
 *   - Here both classes use a real `crypto_kem_keypair()` so the dec runs
 *     its normal path. The keypair call lives OUTSIDE the timed region.
 */

#include <stddef.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

{% if clock == "rdtsc" -%}
#include <x86intrin.h>
{% else -%}
#include <time.h>
{% endif %}

#include "{{ header }}"
{% for h in extra_headers -%}
#include "{{ h }}"
{% endfor %}

/* CTKAT_USE: force `x` to be materialized (treated as observed) before the
 * next instruction, and act as a compiler memory barrier. Defends against
 * the compiler eliding an unused return value or hoisting loads/stores
 * across the timed region. Pair with `-fno-lto` so the function body
 * itself can't be inlined and analyzed for purity. */
#define CTKAT_USE(x) __asm__ __volatile__("" : : "g"(x) : "memory")

#define CTKAT_MEASUREMENTS {{ measurements }}
#define CTKAT_WARMUP       {{ warmup }}
#define CTKAT_SEED         {{ seed }}ULL

static uint64_t prng_state;

static uint64_t prng_next(void) {
    uint64_t x = prng_state;
    x ^= x << 13;
    x ^= x >> 7;
    x ^= x << 17;
    prng_state = x ? x : 0xC0FFEEULL;
    return prng_state;
}

static void prng_init(uint64_t seed) {
    prng_state = seed ? seed : 0xC0FFEEULL;
    for (int i = 0; i < 8; i++) (void)prng_next();
}

static void rand_bytes(uint8_t *buf, size_t len) {
    for (size_t i = 0; i < len; i++) {
        buf[i] = (uint8_t)(prng_next() & 0xff);
    }
}

/* Bundle J (R1 Option B): override PQClean's `randombytes` so KEM
 * `keypair`/`enc` draw from our xorshift PRNG seeded by CTKAT_SEED rather
 * than OS entropy (`getrandom`/`/dev/urandom`). When the user excludes
 * PQClean's `common/randombytes.c` from `sources:`, this weak symbol
 * becomes the only definition → keypair/enc deterministic across runs →
 * `dudect_raw_timings.csv` bit-identical reproducibility (modulo R3
 * system noise).
 *
 * Weak attribute: if PQClean's strong `randombytes` is still in the link
 * (legacy behavior), the linker picks the strong one, so this opt-in
 * doesn't break setups that haven't migrated. See README §"재현성 (seed)"
 * for the opt-in instructions.
 *
 * GCC/Clang only — Windows MSVC has different weak-symbol semantics
 * (__declspec(selectany)), not currently supported. */
__attribute__((weak)) int randombytes(uint8_t *buf, size_t len) {
    rand_bytes(buf, len);
    return 0;
}

{% if clock == "rdtsc" -%}
/* See timing_generic.c.j2 for the rationale behind the lfence-rdtscp-lfence
 * pattern. Same fence on both ends so any inflight insns drain before, and
 * subsequent insns cannot speculate past, the cycle sample. */
static inline uint64_t ctkat_now(void) {
    unsigned int aux;
    _mm_lfence();
    uint64_t t = __rdtscp(&aux);
    _mm_lfence();
    return t;
}
{% else -%}
static inline uint64_t ctkat_now(void) {
    struct timespec ts;
    /* clock_gettime is a vDSO/syscall — already a compiler memory barrier
     * and a CPU sync point, so no extra fence is needed here. */
    clock_gettime(CLOCK_MONOTONIC_RAW, &ts);
    return (uint64_t)ts.tv_sec * 1000000000ULL + (uint64_t)ts.tv_nsec;
}
{% endif %}

static uint64_t cycles_buf[CTKAT_MEASUREMENTS];
static uint8_t  classes_buf[CTKAT_MEASUREMENTS];

int main(void) {
    prng_init(CTKAT_SEED);

{% if leak_target | default("sk") == "fo" %}
    /* === fo-leak mode (Bundle K, U2 #1) ===
     * sk held constant. class 0 sees a VALID ct (generated by enc() each
     * iteration), class 1 sees a RANDOM/invalid ct. dec() under class 1
     * is forced into the FO fallback / implicit-rejection path. Detects
     * timing leaks between the normal-path and the rejection-path —
     * e.g. an early-return on rejection vs uniform re-encryption check. */
    uint8_t pk_fixed   [{{ prefix }}CRYPTO_PUBLICKEYBYTES];
    uint8_t sk_fixed   [{{ prefix }}CRYPTO_SECRETKEYBYTES];
    uint8_t ct_valid   [{{ prefix }}CRYPTO_CIPHERTEXTBYTES];
    uint8_t ct_invalid [{{ prefix }}CRYPTO_CIPHERTEXTBYTES];
    uint8_t ss[{{ prefix }}CRYPTO_BYTES];

    /* Fixed keypair — held constant for the whole run. */
    {{ prefix }}crypto_kem_keypair(pk_fixed, sk_fixed);

    /* warmup — burn-in. fo-leak measures both normal and FO paths, so
     * the warm path choice is symmetric; we use a random ct (FO path) for
     * the burn-in since the FO path tends to take longer and dominates
     * branch-predictor / cache state at the start of the measured loop. */
    for (size_t i = 0; i < CTKAT_WARMUP; i++) {
        rand_bytes(ct_invalid, sizeof(ct_invalid));
        {{ prefix }}crypto_kem_dec(ss, ct_invalid, sk_fixed);
    }

    for (size_t i = 0; i < CTKAT_MEASUREMENTS; i++) {
        int cls = (int)((prng_next() >> 32) & 1ULL);

        uint8_t *ct;
        if (cls == 0) {
            /* Fresh VALID ct via enc() — call OUTSIDE the timed region. */
            {{ prefix }}crypto_kem_enc(ct_valid, ss, pk_fixed);
            ct = ct_valid;
        } else {
            /* Random bytes → invalid ct with overwhelming probability.
             * dec() will take the FO fallback / implicit-rejection path. */
            rand_bytes(ct_invalid, sizeof(ct_invalid));
            ct = ct_invalid;
        }

        {{ emit_kem_measurement('sk_fixed', 'ct') }}
    }
{% elif leak_target | default("sk") == "ct" %}
    /* === ct-leak mode ===
     * sk is held constant across BOTH classes; ct is the fixed-vs-random
     * axis. Detects branches/lookups indexed by common ct content. NOT
     * effective against rare/adversarial ct triggers or operand-latency leaks
     * such as KyberSlash; those need dedicated vectors or div/mul operand
     * analysis. */
    uint8_t pk_fixed  [{{ prefix }}CRYPTO_PUBLICKEYBYTES];
    uint8_t sk_fixed  [{{ prefix }}CRYPTO_SECRETKEYBYTES];
    uint8_t ct_fixed  [{{ prefix }}CRYPTO_CIPHERTEXTBYTES];
    uint8_t ct_random [{{ prefix }}CRYPTO_CIPHERTEXTBYTES];
    uint8_t ss[{{ prefix }}CRYPTO_BYTES];

    /* Fixed keypair — held constant for the whole run. */
    {{ prefix }}crypto_kem_keypair(pk_fixed, sk_fixed);

    /* Fixed ct — generated once via enc() so it's a *valid* ciphertext
     * (exercises the normal dec path, not the FO fallback). `ss` is
     * clobbered here but rewritten by every later dec() anyway. */
    {{ prefix }}crypto_kem_enc(ct_fixed, ss, pk_fixed);

    /* warmup — burn-in microarch state with the valid ct (same normal
     * path the measured loop exercises). F14: previously used a random
     * ct_warm here, which forced burn-in onto the FO path while the
     * measured dec runs the normal path. */
    for (size_t i = 0; i < CTKAT_WARMUP; i++) {
        {{ prefix }}crypto_kem_dec(ss, ct_fixed, sk_fixed);
    }

    for (size_t i = 0; i < CTKAT_MEASUREMENTS; i++) {
        int cls = (int)((prng_next() >> 32) & 1ULL);

        uint8_t *ct;
        if (cls == 0) {
            ct = ct_fixed;
        } else {
            /* Fresh valid ct via enc() — call is OUTSIDE the timed region.
             * Same pk_fixed so the resulting ct decapsulates under the
             * same sk; only the ct *content* varies between classes. */
            {{ prefix }}crypto_kem_enc(ct_random, ss, pk_fixed);
            ct = ct_random;
        }

        {{ emit_kem_measurement('sk_fixed', 'ct') }}
    }
{% else %}
    /* === sk-leak mode (default) ===
     * sk is the fixed-vs-random axis. Both classes use a VALID ct
     * generated by enc() against the SAME pk that produced the sk being
     * measured — so the dec exercises the *normal* path (not the FO
     * fallback). Detects sk-dependent branches/lookups inside the normal
     * dec path.
     *
     * F13 (v6 audit): prior versions filled ct with `rand_bytes(ct)` for
     * both classes, which made dec() take the FO fallback every iteration
     * — the harness then measured "rejection path varies with sk" instead
     * of the advertised "normal dec path varies with sk". The fo-leak
     * brunch above is now the dedicated home for FO-path measurement;
     * sk-leak measures normal-path. */
    uint8_t pk_fixed [{{ prefix }}CRYPTO_PUBLICKEYBYTES];
    uint8_t sk_fixed [{{ prefix }}CRYPTO_SECRETKEYBYTES];
    uint8_t pk_random[{{ prefix }}CRYPTO_PUBLICKEYBYTES];
    uint8_t sk_random[{{ prefix }}CRYPTO_SECRETKEYBYTES];
    uint8_t ct      [{{ prefix }}CRYPTO_CIPHERTEXTBYTES];
    uint8_t ss[{{ prefix }}CRYPTO_BYTES];

    /* class-0 fixed keypair, used unchanged for every class-0 sample */
    {{ prefix }}crypto_kem_keypair(pk_fixed, sk_fixed);

    /* warmup — burn-in microarch state with a valid ct under sk_fixed
     * (same normal-path that the measured loop will exercise). */
    {{ prefix }}crypto_kem_enc(ct, ss, pk_fixed);
    for (size_t i = 0; i < CTKAT_WARMUP; i++) {
        {{ prefix }}crypto_kem_dec(ss, ct, sk_fixed);
    }

    for (size_t i = 0; i < CTKAT_MEASUREMENTS; i++) {
        /* Use a high bit (>>32) instead of the LSB — xorshift64's LSB has
         * known weak diffusion and would give a slightly biased 0/1 split.
         * dudect's t-test needs unbiased class assignment. */
        int cls = (int)((prng_next() >> 32) & 1ULL);

        uint8_t *sk;
        if (cls == 0) {
            sk = sk_fixed;
            /* Fresh valid ct that decapsulates under sk_fixed — enc with
             * pk_fixed. Call is OUTSIDE the timed region. */
            {{ prefix }}crypto_kem_enc(ct, ss, pk_fixed);
        } else {
            /* Fresh valid keypair + valid ct under pk_random — both calls
             * OUTSIDE the timed region. */
            {{ prefix }}crypto_kem_keypair(pk_random, sk_random);
            sk = sk_random;
            {{ prefix }}crypto_kem_enc(ct, ss, pk_random);
        }

        {{ emit_kem_measurement('sk', 'ct') }}
    }
{% endif %}

    printf("sample_id,class,cycles\n");
    for (size_t i = 0; i < CTKAT_MEASUREMENTS; i++) {
        printf("%zu,%u,%llu\n",
               i,
               (unsigned)classes_buf[i],
               (unsigned long long)cycles_buf[i]);
    }
    return 0;
}
